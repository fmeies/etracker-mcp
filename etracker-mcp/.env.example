# Port the MCP server listens on
PORT=3000

# etracker Report IDs (optional — override defaults per account)
# Use the list_reports tool to discover available report IDs.
# ETRACKER_REPORT_PAGEVIEWS=EATime
# ETRACKER_REPORT_CONVERSIONS=EAConversion
# ETRACKER_REPORT_AD=EAMarketing

# MCP server access keys → partner IDs (JSON object)
# Used for access control and rate limiting only.
# Generate keys with: openssl rand -hex 32
# The etracker API token is NOT stored here — partners pass it via X-ET-Token header.
PARTNER_API_KEYS={"key-blablub":"partner-a","key-blafasel":"partner-b"}
